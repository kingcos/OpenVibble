    "onboarding.welcome.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Welcome to Claude Buddy" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "欢迎使用 Claude Buddy" } }
      }
    },
    "onboarding.welcome.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your iPhone becomes Claude Desktop's Hardware Buddy over Bluetooth. Watch your pet react to sessions, level up on tokens, and approve permissions from your phone." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "让你的 iPhone 通过蓝牙成为 Claude Desktop 的硬件伙伴。宠物会跟着会话状态变化、随 Token 升级，也能在手机上一键允许/拒绝权限。" } }
      }
    },
    "onboarding.rename.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Rename Your iPhone" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "先重命名你的 iPhone" } }
      }
    },
    "onboarding.rename.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Claude Desktop only finds devices whose name starts with \"Claude\". Open iOS Settings → General → About → Name and set it to \"Claude\" (or \"Claude-iPhone\", \"Claude-Air\", etc.)." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Claude Desktop 只会扫描以 Claude 开头的设备名。请打开 iOS 的 设置 → 通用 → 关于本机 → 名称，把它改成 \"Claude\"（或 \"Claude-iPhone\"、\"Claude-Air\" 等）。" } }
      }
    },
    "onboarding.rename.hint" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "If Claude Desktop still can't find your iPhone after renaming, restart the phone once — iOS caches the Bluetooth broadcast name." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "如果重命名后 Claude Desktop 仍然搜不到，请重启一次 iPhone —— 系统会缓存蓝牙广播名。" } }
      }
    },
    "onboarding.rename.openSettings" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Open Settings" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "打开系统设置" } }
      }
    },
    "onboarding.pair.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Pair in Claude Desktop" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "在 Claude Desktop 配对" } }
      }
    },
    "onboarding.pair.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Enable Developer Mode in Claude Desktop, then open Developer → Hardware Buddy and pick your iPhone from the list. You can push character packs from the same panel." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "在 Claude Desktop 里打开开发者模式，进入 Developer → Hardware Buddy，在列表里选中你的 iPhone。在同一个面板也能推送宠物包。" } }
      }
    },

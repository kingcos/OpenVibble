    "onboarding.welcome.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your iPhone becomes Claude Desktop's Hardware Buddy over Bluetooth. Watch your pet react to sessions, level up on tokens, and approve permissions from your phone."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让你的 iPhone 通过蓝牙成为 Claude Desktop 的硬件伙伴。宠物会跟着会话状态变化、随 Token 升级，也能在手机上一键允许/拒绝权限。"
          }
        }
      }
    },

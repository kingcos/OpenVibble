    "info.about.body1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your iPhone becomes Claude Desktop's Hardware Buddy over BLE. Watch your buddy react to sessions, approve permissions, and level up as tokens accumulate."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让你的 iPhone 通过蓝牙成为 Claude Desktop 的硬件伙伴。宠物会随会话状态变化，也能在手机上回复权限请求，并随 Token 升级。"
          }
        }
      }
    },
    "info.about.body2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This iOS port replaces the ESP32 firmware — no extra hardware required."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本 iOS 版本直接替代 ESP32 固件，无需额外硬件。"
          }
        }
      }
    },
    "info.about.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude Buddy Bridge"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude Buddy Bridge"
          }
        }
      }
    },
    "info.claude.body1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pair this app from Claude Desktop's Hardware Buddy panel. Advertising uses the Nordic UART Service. iPhone name must start with \"Claude\" — set it in iOS Settings → General → About → Name."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 Claude Desktop 的 Hardware Buddy 面板完成配对。广播使用 Nordic UART Service，iPhone 的名称必须以 Claude 开头 —— 在 设置 → 通用 → 关于本机 → 名称 中修改。"
          }
        }
      }
    },
    "info.claude.body2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When the bridge sends a character pack, it lands in Application Support and appears in the species picker automatically."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude Desktop 推送的宠物包会落在 Application Support 目录，宠物选择器会自动显示。"
          }
        }
      }
    },
    "info.claude.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude Desktop"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude Desktop"
          }
        }
      }
    },
    "info.credits.body1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Original ESP32 firmware + protocol: claude-desktop-buddy."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "原始 ESP32 固件与协议：claude-desktop-buddy。"
          }
        }
      }
    },
    "info.credits.body2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ASCII cat sprites ported from the firmware's buddies/cat.cpp."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ASCII 小猫动画移植自原固件的 buddies/cat.cpp。"
          }
        }
      }
    },
    "info.credits.body3" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Built-in Bufo pet and GIF packs are user-installed via Claude Desktop."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "内置 Bufo 宠物以及其他 GIF 包来自 Claude Desktop 推送。"
          }
        }
      }
    },

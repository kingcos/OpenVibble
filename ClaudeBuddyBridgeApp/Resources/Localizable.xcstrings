    "onboarding.cta.start" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开始使用"
          }
        }
      }
    },
    "onboarding.pair.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable Developer Mode in Claude Desktop, then open Developer → Hardware Buddy and pick your iPhone from the list. You can push character packs from the same panel."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 Claude Desktop 里打开开发者模式，进入 Developer → Hardware Buddy，在列表里选中你的 iPhone。在同一个面板也能推送宠物包。"
          }
        }
      }
    },
    "onboarding.pair.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pair in Claude Desktop"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 Claude Desktop 配对"
          }
        }
      }
    },
    "onboarding.rename.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude Desktop only finds devices whose name starts with \"Claude\". Open iOS Settings → General → About → Name and set it to \"Claude\" (or \"Claude-iPhone\", \"Claude-Air\", etc.)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude Desktop 只会扫描以 Claude 开头的设备名。请打开 iOS 的 设置 → 通用 → 关于本机 → 名称，把它改成 \"Claude\"（或 \"Claude-iPhone\"、\"Claude-Air\" 等）。"
          }
        }
      }
    },
    "onboarding.rename.hint" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If Claude Desktop still can't find your iPhone after renaming, restart the phone once — iOS caches the Bluetooth broadcast name."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {

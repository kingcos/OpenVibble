    <!-- Advertising help -->
    <string name="home_help_title">Help</string>
    <string name="home_help_claude_code_title">If you are using Claude Code</string>
    <string name="home_help_claude_code_body">Claude Code needs to be paired with OpenVibble Desktop to bridge into your Android device.</string>
    <string name="home_help_claude_code_link">Download OpenVibble Desktop</string>
    <string name="home_help_rename_title">If Claude Desktop cannot find this device</string>
    <string name="home_help_rename_body">Claude Desktop scans for names starting with Claude. Copy the suggested handle and paste it into the device name in Bluetooth settings. On some systems, this lives under About phone → Device name.</string>
    <string name="home_help_rename_open_settings">Open Bluetooth Settings</string>
    <string name="home_help_rename_manual_hint">Open Bluetooth settings and paste the handle above as this device name, or use About phone → Device name if your system exposes it there.</string>


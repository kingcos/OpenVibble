    "desktop.overview.hooksCTA.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hooks not registered"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hooks 尚未注册"
          }
        }
      }
    },
    "desktop.overview.hooksCTA.desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude Code won't forward events to OpenVibble until you register hooks in ~/.claude/settings.json. This is reversible."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude Code 需要在 ~/.claude/settings.json 注册 hooks 后才会把事件转发给 OpenVibble。该操作可随时撤销。"
          }
        }
      }
    },

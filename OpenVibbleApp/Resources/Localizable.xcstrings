    "info.claude.body1" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pair this app from Claude Desktop's Hardware Buddy panel. Advertising uses the Nordic UART Service. iPhone name must start with \"Claude\" — set it in iOS Settings → General → About → Name."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 Claude Desktop 的 Hardware Buddy 面板完成配对。广播使用 Nordic UART Service，iPhone 的名称必须以 Claude 开头 —— 在 设置 → 通用 → 关于本机 → 名称 中修改。"
          }
        }
      }
    },

    "info.about.body1" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your iPhone becomes Claude Desktop's Hardware Buddy over BLE. Watch your pet react to sessions, approve permissions, and level up as tokens accumulate."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让你的 iPhone 通过蓝牙成为 Claude Desktop 的硬件伙伴。宠物会随会话状态变化，也能在手机上回复权限请求，并随 Token 升级。"
          }
        }
      }
    },
